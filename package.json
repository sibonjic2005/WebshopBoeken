{
  "name": "boekenhandel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "db": "docker compose up -d",
    "migrate": "docker compose exec db psql -U boekenhandel -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public;' -f /migrations/001_schema.sql -f /migrations/002_seed.sql",
    "dev": "bun run db && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint && next lint",
    "import-books": "bun run scripts/import-books.ts"
  },
  "dependencies": {
    "next": "16.1.6",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
